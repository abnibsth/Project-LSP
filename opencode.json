{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "figma": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "figma-developer-mcp",
                "--stdio"
            ],
            "environment": {
                "FIGMA_API_KEY": ""
            },
            "timeout": 30000
        }
    }
}
